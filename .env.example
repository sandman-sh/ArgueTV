# ═══════════════════════════════════════════════════════════════════════════════
# ArgueTV — Environment Variables
# Copy this file to .env and fill in your API keys
# For Vercel: Add ALL variables marked ✅ REQUIRED in your project settings
# ═══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# ✅ REQUIRED — AI/LLM (OpenRouter or OpenAI)
# The API server WILL CRASH without these two variables.
# Get your key at: https://openrouter.ai/keys
# ──────────────────────────────────────────────────────────────────────────────
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://127.0.0.1:22772
OPENROUTER_APP_NAME=ArgueTV

# ──────────────────────────────────────────────────────────────────────────────
# ✅ REQUIRED — Firecrawl (Live Web Research & Fact-Checking)
# Without this: debates still work but fact-checks use AI knowledge only.
# Get your key at: https://www.firecrawl.dev/
# ──────────────────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# ✅ REQUIRED — ElevenLabs (Voice Synthesis / TTS)
# Without this: debates generate text but NO audio plays.
# Get your key at: https://elevenlabs.io/
# ──────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# Local Development (not needed for Vercel)
# ──────────────────────────────────────────────────────────────────────────────
PORT=8080
API_PORT=8080
WEB_PORT=22772
BASE_PATH=/
