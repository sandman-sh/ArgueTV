{
  "name": "argue-tv-workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead'); process.exit(1)}\"",
    "dev:api": "corepack pnpm --filter @workspace/api-server dev",
    "dev:web": "corepack pnpm --filter @workspace/argue-tv dev",
    "build": "corepack pnpm run typecheck && corepack pnpm -r --if-present run build",
    "typecheck:packages": "tsc --build",
    "typecheck": "corepack pnpm run typecheck:packages && corepack pnpm -r --filter \"./src/apps/**\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
