{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "corepack pnpm install --frozen-lockfile",
  "buildCommand": "corepack pnpm --filter @workspace/argue-tv build",
  "outputDirectory": "src/apps/web/dist/public",
  "functions": {
    "api/[...route].ts": {
      "maxDuration": 300
    }
  }
}
